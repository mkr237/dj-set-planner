# Spotify OAuth credentials
# Get these from https://developer.spotify.com/dashboard
#
# Steps:
#   1. Create a new app in the Spotify Developer Dashboard
#   2. Add http://localhost:5173/callback as a Redirect URI
#   3. Copy the Client ID below (no client secret needed — PKCE flow)
#   4. Copy this file to .env.local and fill in your values

VITE_SPOTIFY_CLIENT_ID=your_client_id_here

# Optional — defaults to http://localhost:5173/callback
# VITE_SPOTIFY_REDIRECT_URI=http://localhost:5173/callback
